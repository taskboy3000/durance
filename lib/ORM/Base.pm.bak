package ORM::Base;
use strict;
use warnings;
use DBI;
use DBD::SQLite;
use Carp qw(croak);
use Mojo::Base -base;

our $DBH;
our (%_table, %_columns, %_primary_key, %_relationships, %_dbh, %_dbname, %COLUMN_META);

sub dbh {
    my ($self, $dbh) = @_;
    
    my $class = ref $self || $self;
    
    if (defined $dbh) {
        if (ref $self) {
            $self->{dbh} = $dbh;
            return $self;
        }
        $_dbh{$class} = $dbh;
        return;
    }
    
    if (ref $self) {
        return $self->{dbh} if exists $self->{dbh};
    }
    
    return $_dbh{$class};
}

sub dbname {
    my ($self, $dbname) = @_;
    
    my $class = ref $self || $self;
    
    if (defined $dbname) {
        if (ref $self) {
            $self->{dbname} = $dbname;
            return $self;
        }
        $_dbname{$class} = $dbname;
        return;
    }
    
    if (ref $self) {
        return $self->{dbname} if exists $self->{dbname};
    }
    
    return $_dbname{$class};
}

sub import {
    my ($class) = @_;
    my $caller_pkg = caller;
    
    no strict 'refs';
    *{"${caller_pkg}::column"} = sub {
        my ($name, @opts) = @_;
        my %opts = @opts;
        my $pkg = caller;
        
        $_columns{$pkg} //= [];
        push @{$_columns{$pkg}}, $name;
        
        $COLUMN_META{$pkg}{$name} = \%opts;
        
        if ($opts{primary_key}) {
            $_primary_key{$pkg} = $name;
        }
        
        my $is = $opts{is} // 'rw';
        
        if ($is eq 'rw') {
            *{"${pkg}::${name}"} = sub {
                my ($self, $val) = @_;
                if (defined $val) {
                    $self->{$name} = $val;
                    return $self;
                }
                return $self->{$name};
            };
        }
        else {
            *{"${pkg}::${name}"} = sub {
                my ($self) = @_;
                return $self->{$name};
            };
        }
        
        return;
    };
}

sub column {
    my ($class, $name, $opts) = @_;
    
    $_columns{$class} //= [];
    push @{$_columns{$class}}, $name;
    
    if ($opts->{primary_key}) {
        $_primary_key{$class} = $name;
    }
    
    my $is = $opts->{is} // 'rw';
    
    if ($is eq 'rw') {
        *{"${class}::${name}"} = sub {
            my ($self, $val) = @_;
            if (defined $val) {
                $self->{$name} = $val;
                return $self;
            }
            return $self->{$name};
        };
    }
    else {
        *{"${class}::${name}"} = sub {
            my ($self) = @_;
            return $self->{$name};
        };
    }
    
    return;
}

sub new {
    my ($class, %args) = @_;
    
    my $dbh = $args{dbh};
    my $dbname = $args{dbname};
    
    if (!$dbh && !$dbname) {
        $dbname = $ORM::Base::DBNAME;
        $dbh = $_dbh{$class};
    }
    
    if ($dbname && !$dbh) {
        $dbh = DBI->connect("dbi:SQLite:dbname=$dbname", '', '', {
            RaiseError => 1,
            AutoCommit => 1,
        });
    }
    
    if ($dbh) {
        $args{dbh} = $dbh;
    }
    if ($dbname) {
        $args{dbname} = $dbname;
    }
    
    my $self = $class->SUPER::new(%args);
    
    $self->BUILD;
    
    return $self;
}

sub table {
    my ($class) = @_;
    return $_table{$class} if $_table{$class};
    my $name = ref $class ? ref $class : $class;
    $name =~ s/::/_/g;
    $name = lc $name;
    $name =~ s/([a-z])([A-Z])/$1_$2/g;
    $name =~ s/y$/ies/ if length $name > 1;
    $name .= 's' unless $name =~ /s$/;
    return $name;
}

sub column_meta {
    my ($class, $column) = @_;
    return $COLUMN_META{$class}{$column} // {};
}

sub columns {
    my ($class) = @_;
    return $_columns{$class} // [];
}

sub primary_key {
    my ($class) = @_;
    return $_primary_key{$class} // 'id';
}

sub find {
    my ($class, $id) = @_;
    my $pk = $class->primary_key;
    my $table = $class->table;
    my $dbh = $class->dbh // croak 'No database handle';
    
    my $stmt = "SELECT * FROM $table WHERE $pk = ?";
    my $sth = $dbh->prepare($stmt);
    $sth->execute($id);
    
    my $row = $sth->fetchrow_hashref;
    $sth->finish;
    
    return undef unless $row;
    
    return $class->new(%$row, dbh => $dbh, dbname => $class->dbname);
}

sub all {
    my ($class) = @_;
    my $table = $class->table;
    my $dbh = $class->dbh // croak 'No database handle';
    
    my $stmt = "SELECT * FROM $table";
    my $sth = $dbh->prepare($stmt);
    $sth->execute;
    
    my @rows;
    while (my $row = $sth->fetchrow_hashref) {
        push @rows, $class->new(%$row, dbh => $dbh, dbname => $class->dbname);
    }
    $sth->finish;
    
    return @rows;
}

sub where {
    my ($class, $conditions) = @_;
    my $table = $class->table;
    my $dbh = $class->dbh // croak 'No database handle';
    
    return $class->all unless $conditions && %$conditions;
    
    my @cols = keys %$conditions;
    my @vals = values %$conditions;
    my $where = join ' AND ', map { "$_ = ?" } @cols;
    
    my $stmt = "SELECT * FROM $table WHERE $where";
    my $sth = $dbh->prepare($stmt);
    $sth->execute(@vals);
    
    my @rows;
    while (my $row = $sth->fetchrow_hashref) {
        push @rows, $class->new(%$row, dbh => $dbh, dbname => $class->dbname);
    }
    $sth->finish;
    
    return @rows;
}

sub create {
    my ($class, $data) = @_;
    my $dbh = $class->dbh // croak 'No database handle';
    
    return $class->new(%$data, dbh => $dbh, dbname => $class->dbname)->insert;
}

sub _columns_info {
    my ($class) = @_;
    return {};
}

sub insert {
    my ($self) = @_;
    my $table = ref($self)->table;
    my $dbh = $self->dbh // croak 'No database handle';
    
    my @cols = grep { defined $self->{$_} && $_ ne 'dbh' && $_ ne 'dbname' } keys %$self;
    return $self unless @cols;
    
    my @vals = map { $self->{$_} } @cols;
    my $placeholders = join ', ', map { '?' } @cols;
    my $col_list = join ', ', @cols;
    
    my $stmt = "INSERT INTO $table ($col_list) VALUES ($placeholders)";
    my $sth = $dbh->prepare($stmt);
    $sth->execute(@vals);
    $sth->finish;
    
    my $pk = ref($self)->primary_key;
    unless (defined $self->{$pk}) {
        my $id = $dbh->last_insert_id(undef, undef, $table, undef);
        $self->{$pk} = $id if defined $id;
    }
    
    return $self;
}

sub update {
    my ($self) = @_;
    my $table = ref($self)->table;
    my $dbh = $self->dbh // croak 'No database handle';
    
    my $pk = ref($self)->primary_key;
    my $pk_val = $self->{$pk} // croak "Cannot update without primary key value";
    
    my @cols = grep { defined $self->{$_} && $_ ne 'dbh' && $_ ne 'dbname' && $_ ne $pk } keys %$self;
    return $self unless @cols;
    
    my @vals = map { $self->{$_} } @cols;
    my $set_clause = join ', ', map { "$_ = ?" } @cols;
    
    my $stmt = "UPDATE $table SET $set_clause WHERE $pk = ?";
    my $sth = $dbh->prepare($stmt);
    $sth->execute(@vals, $pk_val);
    $sth->finish;
    
    return $self;
}

sub delete {
    my ($self) = @_;
    my $table = ref($self)->table;
    my $dbh = $self->dbh // croak 'No database handle';
    
    my $pk = ref($self)->primary_key;
    my $pk_val = $self->{$pk} // croak "Cannot delete without primary key value";
    
    my $stmt = "DELETE FROM $table WHERE $pk = ?";
    my $sth = $dbh->prepare($stmt);
    $sth->execute($pk_val);
    $sth->finish;
    
    return $self;
}

sub save {
    my ($self) = @_;
    my $pk = ref($self)->primary_key;
    my $pk_val = $self->{$pk};
    
    if (defined $pk_val && $pk_val ne '') {
        return $self->update;
    }
    return $self->insert;
}

sub to_hash {
    my ($self) = @_;
    my %hash = %$self;
    delete $hash{dbh};
    delete $hash{dbname};
    delete $hash{$_} for grep { !defined $self->{$_} } keys %hash;
    return \%hash;
}

sub BUILD {
    my ($self) = @_;
    my $class = ref $self;
    
    $_columns{$class} //= [];
    $_primary_key{$class} //= 'id';
    $_relationships{$class} //= {};
    
    return $self;
}

1;
